generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "auth"]
}

model Project {
  id          String   @id @default(uuid())
  title       String
  category    String
  videoUrl    String?
  thumbnail   String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model Message {
  id        String   @id @default(uuid())
  email     String
  subject   String
  content   String
  createdAt DateTime @default(now())

  @@schema("public")
}

model MediaAsset {
  id        String   @id @default(uuid())
  fileName  String
  publicUrl String
  objectKey String?
  mimeType  String
  fileSize  Int?
  folder    String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([objectKey])
  @@index([createdAt])
  @@schema("public")
}
